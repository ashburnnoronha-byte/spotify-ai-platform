# Copy to .env.production and fill in before: docker compose -f docker-compose.prod.yml up -d
# Do not commit .env.production.

POSTGRES_PASSWORD=change-me-strong-password
SECRET_KEY=change-me-openssl-rand-hex-32
TOKEN_ENCRYPTION_KEY=change-me-fernet-key

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://YOUR_HOST/api/v1/auth/callback
FRONTEND_URL=https://YOUR_HOST
CORS_ORIGINS=["https://YOUR_HOST"]

LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
USE_OPENAI_EMBEDDINGS=false
