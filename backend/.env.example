# Application
DEBUG=false
SECRET_KEY=your-secret-key-min-32-chars-long
TOKEN_ENCRYPTION_KEY=NmqI5V4VRbxW9g7uVtX7kfv7bVHmcK8kHfh5Lcanqic==

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spotify_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=63bd6c87a4f34ffabace994fb154cb02
SPOTIFY_CLIENT_SECRET=bb51f8ad4d7048bb9c8d4016fe550ff2
# Spotify requires loopback URIs to use explicit 127.0.0.1 — localhost is not allowed
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/callback

# Frontend
FRONTEND_URL=http://127.0.0.1:5173
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# AI / RAG
# Gemini has a free tier via Google AI Studio. Local embeddings are still used by default.
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional OpenAI fallback. Set LLM_PROVIDER=openai to use it for chat answers.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
# Keep false for local development to avoid OpenAI embedding quota errors.
USE_OPENAI_EMBEDDINGS=false
CHROMA_PERSIST_DIR=./.chroma
